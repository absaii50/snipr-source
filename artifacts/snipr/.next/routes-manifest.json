{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [
    {
      "source": "/:path*.(woff2|woff|ttf|otf|eot)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ],
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:\\.(woff2|woff|ttf|otf|eot))(?:/)?$"
    },
    {
      "source": "/_next/static/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ],
      "regex": "^/_next/static(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
    },
    {
      "source": "/:path*.(jpg|jpeg|png|gif|svg|ico|webp)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=604800"
        }
      ],
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:\\.(jpg|jpeg|png|gif|svg|ico|webp))(?:/)?$"
    }
  ],
  "rewrites": {
    "beforeFiles": [
      {
        "source": "/api/:path*",
        "destination": "http://localhost:8080/api/:path*",
        "regex": "^/api(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
      }
    ],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/admin/[tab]",
      "regex": "^/admin/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPtab": "nxtPtab"
      },
      "namedRegex": "^/admin/(?<nxtPtab>[^/]+?)(?:/)?$"
    },
    {
      "page": "/analytics/[linkId]",
      "regex": "^/analytics/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPlinkId": "nxtPlinkId"
      },
      "namedRegex": "^/analytics/(?<nxtPlinkId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/links/[id]/rules",
      "regex": "^/links/([^/]+?)/rules(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/links/(?<nxtPid>[^/]+?)/rules(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
