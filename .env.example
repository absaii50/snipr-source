# ===== REQUIRED =====
DATABASE_URL=postgresql://user:password@localhost:5432/snipr_prod
SESSION_SECRET=generate-a-strong-random-secret-here
PORT=8080
NODE_ENV=production

# Admin Panel Credentials
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD_HASH=generate-bcrypt-hash-of-your-password

# Frontend URL (for CORS)
FRONTEND_URL=https://your-domain.com

# ===== AI INTEGRATIONS =====
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
AI_INTEGRATIONS_OPENAI_API_KEY=your-openai-key
OPENAI_API_KEY=your-openai-key
DEEPSEEK_API_KEY=your-deepseek-key

# ===== PAYMENTS (Optional) =====
LEMONSQUEEZY_API_KEY=your-key
LEMONSQUEEZY_STORE_ID=your-store-id
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-secret
